{
  "name": "a2ui-vue",
  "version": "0.8.2-rc.2",
  "type": "module",
  "description": "A2UI Vue3 Renderer",
  "author": "shawnwang15@163.com",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib",
    "build:lib": "vite build --mode lib",
    "typecheck": "vue-tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "dompurify": "^3.3.1",
    "markdown-it": "^14.1.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.17.19",
    "@vitejs/plugin-vue": "^6.0.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.27",
    "vue-tsc": "^2.2.0",
    "@a2ui/web_core": "workspace:*",
    "zod": "^3.25.76"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shawnwang15/a2ui-vue.git"
  },
  "homepage": "https://github.com/shawnwang15/a2ui-vue",
  "keywords": [
    "a2ui","A2UI","a2ui-vue","a2ui-vue3"
  ]
}
